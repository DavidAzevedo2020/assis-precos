# Copie este arquivo para .env.local e preencha com os valores reais.
# NUNCA commite .env.local nem cole segredos reais no chat.

# Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (Project Settings -> Database -> Connection string, modo "Transaction")
DATABASE_URL=

# E-mail usado para solicitar cotações a fornecedores. SMTP_EMAIL é o
# endereço completo; SMTP_APP_PASSWORD é uma "senha de aplicativo" (não é a
# senha normal da conta) — no Gmail, gere em myaccount.google.com/apppasswords
# (exige verificação em duas etapas ativada). SMTP_HOST/SMTP_PORT são
# opcionais, padrão smtp.gmail.com:587.
SMTP_EMAIL=
SMTP_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=
